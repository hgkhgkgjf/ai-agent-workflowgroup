{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "in-process",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "Task",
      "TodoWrite",
      "Shell(bash scripts/harness/*)",
      "Shell(cat .orchestration/*)",
      "Shell(ls *)",
      "Shell(wc *)"
    ],
    "deny": [
      "Shell(git push *)",
      "Shell(git commit *)",
      "Shell(git merge *)",
      "Shell(git reset --hard *)",
      "Shell(rm -rf *)",
      "Shell(sudo *)"
    ]
  }
}
